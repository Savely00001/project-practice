    <style type='text/css'>
        
        body {
            width: 100%;
            margin: 0 auto;
        }
        header > nav > ul > li > a {
            text-decoration: none;
            color: #111827;
        }
        header > nav > ul > li {
            list-style: none;
            display: inline;
            padding: 1em;
            font-size: 140%;
        }
        header {
            align-items: center;
            display: flex;
            padding: 2%;
            background-color: #ffffff;
            justify-content: space-between;
        }
        nav {
            padding-left: 25%;
        }
        header > nav > ul > li > a:hover {
            color: #21ADFC;
        }
        #partic > a {
            color: #21ADFC;
        }
        header img {
            width: 50px;
            height: 50px;
        }
        .logom {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        footer {
            display: flex;
            justify-content: space-between;
            background-color: #111827;
            color: #ffffff;
            padding: 3%;
            padding-left: 5%;
            padding-right: 5%;
        }
        footer > .bl2 > ul > li {
            list-style: none;
            padding-top: 1em;
            margin-left: auto;
        }
        footer > .bl2 > ul > li > a {
            text-decoration: none;
            color: #ffffff;
        }
        footer > .bl2 > ul  {
            margin: 0;
            padding: 0;
        }
        .footer_bottom {
             background-color: #111827;
            color: #ffffff;
            padding: 2%;
            text-align: center;
        }
        .footer_bottom > p {
            padding-top: 2%;
        }
        .footer_bottom hr {
            border: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #21ADFC, #ffffff, #21ADFC, transparent);
        }
        section > .p {
            text-align: center;
        }
        section > h2 {
            padding-left: 2em;
        }
        article  {
            padding: 2em;
            margin: 1em;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .card {
            width: 25%;
            align-items: center;
            justify-content: space-between;
            display: flex;
            padding: 1em;
            border: 2px solid #111827;
            border-radius: 10px;
        }
        .card li {
            padding-top: 0.5em;
        }
        .card {
    transition: transform 0.3s, box-shadow 0.3s;  /* ← плавность анимации */
}
.card:hover {
    transform: translateY(-5px);  /* ← подъём на 5px вверх */
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);  /* ← тень для объёма */
}
.ava {
    padding-left: 1em;
    padding-right: 1em;
    border-radius: 40px;
    margin-right: 1em;
    background-color: #21ADFC;
    color: #ffffff
}
.d_card {
    margin: 1em;
    padding: 2em;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.card_p {
    padding: 1em;
            border: 2px solid #111827;
            border-radius: 10px;
            width: 20%;
}
.card_not li {
    list-style: numeric;
}
.card_not {
    border: 2px solid #111827;
            border-radius: 10px;
            padding: 1em;
            margin: 3em;
            width: 30%;
}
    </style>
</head>
